{
  "name": "flamingo-cms",
  "private": true,
  "version": "0.1.0",
  "description": "CMS-driven multi-tenant website platform for FlamingoMedia.",
  "scripts": {
    "dev": "npm --workspace=@flamingo/web run dev --",
    "build": "npm run build --workspace=@flamingo/web",
    "lint": "npm run lint --workspace=@flamingo/web",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "test": "vitest run",
    "validate:sections": "tsx scripts/validate-sections.ts",
    "validate:seeds": "tsx scripts/validate-seeds.ts",
    "check:hardcoded-content": "tsx scripts/check-hardcoded-content.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed:showcase": "tsx scripts/seed-showcase.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.4.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^11.2.6",
    "lucide-react": "^0.468.0",
    "next": "^14.2.3",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.5",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  }
}
